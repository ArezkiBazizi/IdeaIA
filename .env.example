# Copier vers .env — ne jamais committer les secrets réels
NODE_ENV=development
PORT=3000

# PostgreSQL (docker-compose : host db, port 5432)
DATABASE_URL=postgresql://idea:idea@127.0.0.1:5433/ideatoaction

# NVIDIA Build (NIM) — clé uniquement via variables d'environnement
NVIDIA_API_KEY=
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/build-autogen-18
NVIDIA_MAX_RETRIES=3
