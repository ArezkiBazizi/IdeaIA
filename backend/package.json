{
  "name": "idea-to-action",
  "version": "1.0.0",
  "description": "Idea-to-Action — transformation d'idées en projets structurés (NVIDIA Build + Fastify + Prisma)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch server.js",
